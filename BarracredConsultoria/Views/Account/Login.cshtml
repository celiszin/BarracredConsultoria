@model BarracredConsultoria.ViewModels.AcessoSessaoViewModel
@{
    Layout = null;
    ViewData["Title"] = "BarraCred - Acesso";
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&family=Open+Sans:wght@400;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
</head>
<body>
    <div class="login-container">
        <div class="login-card">
            <div class="logo-wrapper">
                <div class="logo-image">
                    <img src="https://api.builder.io/api/v1/image/assets/TEMP/22af6039ce9bef78d2c1c13c82d3761107fed74f" alt="Logo cooperativa">
                </div>
            </div>

            @if (TempData["MensagemSucesso"] != null)
            {
                <div class="validation-summary-errors" style="background-color: #d1fae5; color: #065f46; border: 1px solid #10b981; padding: 12px; border-radius: 8px; margin-bottom: 16px;">
                    @TempData["MensagemSucesso"]
                </div>
            }

            <div class="form-box" id="loginSection">
                <div class="title-section">
                    <div class="main-title">Acesse sua conta</div>
                    <div class="subtitle">Entre com suas credenciais para gerenciar sua<br />saúde financeira.</div>
                </div>

                @if (ViewBag.Error != null)
                {
                    <div class="validation-summary-errors" role="alert">@ViewBag.Error</div>
                }

                <form asp-controller="Account" asp-action="Login" method="POST" class="form-fields">
                    <input type="hidden" asp-for="Login.UrlRetorno" />

                    <div class="input-group">
                        <label asp-for="Login.Email" class="input-label">E-mail</label>
                        <div class="input-wrapper">
                            <input asp-for="Login.Email" type="email" class="input-field" placeholder="seu@email.com" autocomplete="username">
                        </div>
                        <span asp-validation-for="Login.Email" class="field-validation-error"></span>
                    </div>

                    <div style="margin-top: 24px;"></div>
                    
                    <div class="input-group">
                        <div class="senha-header">
                            <label asp-for="Login.Senha" class="senha-label">Senha</label>
                            <a href="javascript:void(0)" class="forgot-link" onclick="showSection('forgotSection')">Esqueci minha senha</a>
                        </div>
                        <div class="input-wrapper">
                            <input asp-for="Login.Senha" type="password" class="input-field" id="Login_Senha" placeholder="••••••••" autocomplete="current-password">
                            <button class="eye-button" type="button" onclick="togglePasswordVisibility('Login_Senha', this)">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                </svg>
                            </button>
                        </div>
                        <span asp-validation-for="Login.Senha" class="field-validation-error"></span>
                    </div>

                    <div class="checkbox-wrapper" id="rememberCheckboxWrapper">
                        <input type="checkbox" asp-for="Login.Lembrar" id="rememberMeCheckboxInput" class="hidden" />
                        <div class="checkbox-custom" id="rememberCheckbox"></div>
                        <label asp-for="Login.Lembrar" class="checkbox-label">Lembrar de mim neste dispositivo</label>
                    </div>

                    <button type="submit" class="login-button">
                        Entrar
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
                    </button>
                </form>

                <div class="signup-footer">
                    <div class="signup-container">
                        <span class="signup-text">Ainda não é cooperado?&nbsp;</span>
                        <a href="javascript:void(0)" class="signup-link" onclick="showSection('registerSection')">Cadastre-se</a>
                    </div>
                </div>
            </div>

            <div class="form-box hidden" id="registerSection">
                <div class="title-section">
                    <div class="main-title">Crie sua conta</div>
                    <div class="subtitle">Preencha os dados abaixo para se tornar um cooperado.</div>
                </div>

                @if (ViewBag.ShowRegister == true && !ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="validation-summary-errors" style="margin-bottom: 16px;"></div>
                }

                <form asp-controller="Account" asp-action="Cadastro" method="POST" class="form-fields">
                    <div class="input-group">
                        <label asp-for="Registro.Nome" class="input-label">Nome Completo</label>
                        <div class="input-wrapper">
                            <input asp-for="Registro.Nome" class="input-field" placeholder="Seu nome completo" required>
                        </div>
                    </div>
                    <div style="margin-top: 16px;"></div>

                    <div class="input-group">
                        <label asp-for="Registro.Email" class="input-label">E-mail</label>
                        <div class="input-wrapper">
                            <input asp-for="Registro.Email" type="email" class="input-field" placeholder="seu@email.com" required>
                        </div>
                    </div>
                    <div style="margin-top: 16px;"></div>

                    <div class="input-group">
                        <label asp-for="Registro.DataNascimento" class="input-label">Data de Nascimento</label>
                        <div class="input-wrapper">
                            <input asp-for="Registro.DataNascimento" type="date" class="input-field" required>
                        </div>
                    </div>
                    <div style="margin-top: 16px;"></div>

                    <div class="input-group">
                        <label asp-for="Registro.Senha" class="input-label">Senha</label>
                        <div class="input-wrapper">
                            <input asp-for="Registro.Senha" type="password" class="input-field" id="Reg_Senha" placeholder="••••••••" required>
                            <button class="eye-button" type="button" onclick="togglePasswordVisibility('Reg_Senha', this)">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                            </button>
                        </div>
                    </div>
                    <div style="margin-top: 16px;"></div>

                    <div class="input-group">
                        <label asp-for="Registro.ConfirmacaoSenha" class="input-label">Confirmar Senha</label>
                        <div class="input-wrapper">
                            <input asp-for="Registro.ConfirmacaoSenha" type="password" class="input-field" id="Reg_ConfSenha" placeholder="••••••••" required>
                            <button class="eye-button" type="button" onclick="togglePasswordVisibility('Reg_ConfSenha', this)">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                            </button>
                        </div>
                    </div>

                    <button type="submit" class="login-button" style="margin-top: 32px;">Criar Conta</button>
                </form>

                <div class="signup-footer">
                    <div class="signup-container">
                        <span class="signup-text">Já possui conta?&nbsp;</span>
                        <a href="javascript:void(0)" class="signup-link" onclick="showSection('loginSection')">Fazer Login</a>
                    </div>
                </div>
            </div>

            <div class="form-box hidden" id="forgotSection">
                <div class="title-section">
                    <div class="main-title">Recuperar Senha</div>
                    <div class="subtitle">Informe seu e-mail para receber as instruções de recuperação.</div>
                </div>

                <form asp-controller="Account" asp-action="EsqueciSenha" method="POST" class="form-fields">
                    <div class="input-group">
                        <label asp-for="EsqueciSenha.Email" class="input-label">E-mail Cadastrado</label>
                        <div class="input-wrapper">
                            <input asp-for="EsqueciSenha.Email" type="email" class="input-field" placeholder="seu@email.com" required>
                        </div>
                        <span asp-validation-for="EsqueciSenha.Email" class="field-validation-error"></span>
                    </div>

                    <button type="submit" class="login-button" style="margin-top: 32px;">Enviar Instruções</button>
                </form>

                <div class="signup-footer">
                    <div class="signup-container">
                        <a href="javascript:void(0)" class="signup-link" onclick="showSection('loginSection')">Voltar para Login</a>
                    </div>
                </div>
            </div>

            <div class="secure-badge">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" stroke="#9ca3af">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
                </svg>
                <div class="secure-text">Ambiente 100% Seguro</div>
            </div>
        </div>
    </div>

    <script src="~/js/login.js" asp-append-version="true"></script>
    <script>
        function showSection(id) {
            document.getElementById('loginSection').classList.add('hidden');
            document.getElementById('registerSection').classList.add('hidden');
            document.getElementById('forgotSection').classList.add('hidden');
            document.getElementById(id).classList.remove('hidden');
        }

        @if (ViewBag.ShowRegister == true) { <text>document.addEventListener("DOMContentLoaded", function() { showSection('registerSection'); });</text> }
        @if (ViewBag.ShowForgot == true) { <text>document.addEventListener("DOMContentLoaded", function() { showSection('forgotSection'); });</text> }
    </script>
</body>
</html>