@model BarracredConsultoria.ViewModels.ConsultoriaViewModel

@{
    ViewData["Title"] = "Simulador de Sonhos e Metas";
    Layout = null; 
}

<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] | BarraCred</title>
    
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    
    <script id="tailwind-config">
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        "primary": "#008744",
                        "background-light": "#F8FAFC",
                        "surface": "#FFFFFF",
                        "text-main": "#1A1A1A",
                        "text-muted": "#64748B",
                        "border-color": "#E2E8F0"
                    },
                    fontFamily: {
                        "display": ["Manrope", "sans-serif"]
                    },
                    borderRadius: {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "2xl": "1rem",
                        "full": "9999px"
                    },
                    boxShadow: {
                        "soft": "0 4px 20px -2px rgba(0, 0, 0, 0.05)",
                        "card": "0 10px 15px -3px rgba(0, 0, 0, 0.04), 0 4px 6px -2px rgba(0, 0, 0, 0.02)"
                    }
                },
            },
        }
    </script>
    <style type="text/tailwindcss">
        @@layer base {
            body {
                @@apply bg-background-light text-text-main font-display antialiased;
            }
        }
        .slider-thumb::-webkit-slider-thumb {
            -webkit-appearance: none;
            appearance: none;
            width: 24px;
            height: 24px;
            background: #008744;
            cursor: pointer;
            border-radius: 50%;
            border: 4px solid #FFFFFF;
            box-shadow: 0 2px 8px rgba(0, 135, 68, 0.3);
            transition: transform 0.1s;
        }
        .slider-thumb:active::-webkit-slider-thumb {
            transform: scale(1.15);
        }
        .slider-thumb::-moz-range-thumb {
            width: 24px;
            height: 24px;
            background: #008744;
            cursor: pointer;
            border-radius: 50%;
            border: 4px solid #FFFFFF;
            box-shadow: 0 2px 8px rgba(0, 135, 68, 0.3);
        }
        .glass-panel {
            @@apply bg-surface border border-border-color shadow-soft;
        }

        /* Classes mágicas para os botões de Sonhos */
        .btn-sonho-ativo {
            @@apply border-primary bg-primary/5 text-primary;
        }
        .btn-sonho-inativo {
            @@apply border-transparent bg-background-light text-text-muted hover:border-border-color hover:text-text-main;
        }
    </style>
</head>

<body class="min-h-screen">
    <header class="border-b border-border-color bg-surface/80 backdrop-blur-md sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 h-20 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-primary rounded-lg flex items-center justify-center shadow-lg shadow-primary/20">
                    <span class="material-icons text-white">account_balance</span>
                </div>
                <span class="text-xl font-bold tracking-tight text-text-main">Barra<span class="text-primary">Cred</span></span>
            </div>
            <nav class="hidden md:flex items-center gap-8">
                <a class="text-sm font-semibold text-text-muted hover:text-primary transition-colors" asp-controller="Home" asp-action="Index">Início</a>
                <a class="text-sm font-bold text-primary border-b-2 border-primary pb-1" asp-controller="Home" asp-action="Simulador">Simulador</a>
                <a class="text-sm font-semibold text-text-muted hover:text-primary transition-colors" href="#">Produtos</a>
                <a class="text-sm font-semibold text-text-muted hover:text-primary transition-colors" href="#">Ajuda</a>
            </nav>
            <div class="flex items-center gap-4">
                <div class="text-right hidden sm:block">
                    <p class="text-[10px] uppercase tracking-wider font-bold text-text-muted">Foco: @Model.Usuario.Objetivo</p>
                    <p class="text-sm font-bold text-text-main">Minha Conta</p>
                </div>
                <div class="w-10 h-10 rounded-full bg-primary/10 border border-primary/20 flex items-center justify-center">
                    <span class="material-icons text-primary">person</span>
                </div>
            </div>
        </div>
    </header>
    
    <main class="max-w-7xl mx-auto px-4 py-8 md:py-16">
        
        <section class="mb-12">
            <h1 class="text-4xl md:text-5xl font-extrabold mb-4 text-text-main tracking-tight">
                Simulador de <span class="text-primary">Sonhos e Metas</span>
            </h1>
            <p class="text-text-muted max-w-2xl text-lg leading-relaxed">
                Transforme seus objetivos financeiros em realidade. Descubra quanto guardar por mês para chegar lá.
            </p>
        </section>
        
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
            <div class="lg:col-span-7 space-y-8">
                <div class="glass-panel p-8 rounded-2xl">
                    <h3 class="text-xs font-bold uppercase tracking-[0.15em] text-primary mb-6">1. Qual o seu sonho?</h3>
                    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4" id="botoesSonho">
                        <button class="btn-sonho btn-sonho-ativo flex flex-col items-center gap-3 p-5 rounded-xl border-2 transition-all">
                            <span class="material-icons text-3xl">flight_takeoff</span>
                            <span class="text-xs font-bold uppercase">Viagem</span>
                        </button>
                        <button class="btn-sonho btn-sonho-inativo flex flex-col items-center gap-3 p-5 rounded-xl border-2 transition-all">
                            <span class="material-icons text-3xl">directions_car</span>
                            <span class="text-xs font-bold uppercase">Carro</span>
                        </button>
                        <button class="btn-sonho btn-sonho-inativo flex flex-col items-center gap-3 p-5 rounded-xl border-2 transition-all">
                            <span class="material-icons text-3xl">home</span>
                            <span class="text-xs font-bold uppercase">Casa Própria</span>
                        </button>
                        <button class="btn-sonho btn-sonho-inativo flex flex-col items-center gap-3 p-5 rounded-xl border-2 transition-all">
                            <span class="material-icons text-3xl">school</span>
                            <span class="text-xs font-bold uppercase">Estudos</span>
                        </button>
                    </div>
                </div>
                
                <div class="glass-panel p-8 rounded-2xl space-y-10">
                    <h3 class="text-xs font-bold uppercase tracking-[0.15em] text-primary mb-2">2. Defina os parâmetros</h3>
                    <div class="space-y-4">
                        <div class="flex justify-between items-center">
                            <label class="text-text-main font-bold">Quanto você precisa?</label>
                            <span id="displayValor" class="text-3xl font-black text-primary tracking-tight">R$ 45.000</span>
                        </div>
                        <input id="inputValor" class="w-full h-2.5 bg-border-color rounded-lg appearance-none cursor-pointer slider-thumb" max="250000" min="1000" step="500" type="range" value="45000" />
                        <div class="flex justify-between text-[11px] text-text-muted font-bold uppercase tracking-wider">
                            <span>R$ 1.000</span>
                            <span>R$ 250.000</span>
                        </div>
                    </div>
                    <div class="space-y-4">
                        <div class="flex justify-between items-center">
                            <label class="text-text-main font-bold">Em quanto tempo?</label>
                            <span id="displayTempo" class="text-3xl font-black text-primary tracking-tight">24 Meses</span>
                        </div>
                        <input id="inputTempo" class="w-full h-2.5 bg-border-color rounded-lg appearance-none cursor-pointer slider-thumb" max="120" min="6" step="1" type="range" value="24" />
                        <div class="flex justify-between text-[11px] text-text-muted font-bold uppercase tracking-wider">
                            <span>6 MESES</span>
                            <span>10 ANOS</span>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="lg:col-span-5 space-y-6">
                <div class="bg-primary text-white rounded-2xl p-8 relative overflow-hidden shadow-xl shadow-primary/20">
                    <div class="absolute -top-24 -right-24 w-64 h-64 bg-white/10 blur-[80px] rounded-full"></div>
                    <div class="relative z-10">
                        <h3 class="text-white/80 font-bold uppercase tracking-[0.2em] text-[10px] mb-2">Investimento Mensal Estimado</h3>
                        <div class="flex items-baseline gap-2 mb-8">
                            <span class="text-2xl font-medium text-white/70">R$</span>
                            <span id="calcMensal" class="text-6xl font-black text-white">0,00</span>
                        </div>
                        <div class="p-5 bg-white/10 rounded-xl border border-white/20 flex items-start gap-4 mb-8">
                            <span class="material-icons text-white">trending_up</span>
                            <div>
                                <p class="text-sm font-bold text-white mb-1">Análise de Viabilidade</p>
                                <p id="textViabilidade" class="text-xs text-white/80 leading-relaxed">Calculando viabilidade...</p>
                            </div>
                        </div>
                        <button class="w-full py-4 bg-white text-primary hover:bg-slate-50 font-black rounded-xl shadow-lg flex items-center justify-center gap-3 transition-all active:scale-[0.98] uppercase tracking-wider text-sm">
                            CRIAR ESTA META
                            <span class="material-icons text-lg">arrow_forward</span>
                        </button>
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div class="glass-panel p-5 rounded-2xl">
                        <p class="text-[10px] text-text-muted uppercase font-black tracking-widest mb-1">Total Acumulado</p>
                        <p id="calcAcumulado" class="text-xl font-bold text-text-main">R$ 0,00</p>
                    </div>
                    <div class="glass-panel p-5 rounded-2xl border-l-4 border-l-primary">
                        <p class="text-[10px] text-text-muted uppercase font-black tracking-widest mb-1">Juros a seu favor</p>
                        <p id="calcRendimento" class="text-xl font-bold text-primary">+ R$ 0,00</p>
                    </div>
                </div>
            </div>
        </div>


        <section class="mt-24 pt-16 border-t border-border-color">
            <div class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
                <div>
                    <h2 class="text-3xl font-extrabold text-text-main tracking-tight">O Poder do Aporte Mensal</h2>
                    <p class="text-text-muted mt-2">Veja quanto você terá no futuro se investir um valor fixo por mês com a taxa Selic atual.</p>
                </div>
                <div class="bg-primary/10 border border-primary/20 px-4 py-2 rounded-lg flex items-center gap-2">
                    <span class="material-icons text-primary">percent</span>
                    <span class="text-sm font-bold text-primary">Selic Hoje: 10,75% a.a.</span>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
                <div class="lg:col-span-6 glass-panel p-8 rounded-2xl space-y-10">
                    <div class="space-y-4">
                        <div class="flex justify-between items-center">
                            <label class="text-text-main font-bold">Quanto investir por mês?</label>
                            <span id="displayAporte" class="text-3xl font-black text-primary tracking-tight">R$ 500</span>
                        </div>
                        <input id="inputAporte" class="w-full h-2.5 bg-border-color rounded-lg appearance-none cursor-pointer slider-thumb" max="10000" min="50" step="50" type="range" value="500" />
                        <div class="flex justify-between text-[11px] text-text-muted font-bold uppercase tracking-wider">
                            <span>R$ 50</span>
                            <span>R$ 10.000</span>
                        </div>
                    </div>
                    
                    <div class="space-y-4">
                        <div class="flex justify-between items-center">
                            <label class="text-text-main font-bold">Por quanto tempo?</label>
                            <span id="displayTempoAporte" class="text-3xl font-black text-primary tracking-tight">5 Anos</span>
                        </div>
                        <input id="inputTempoAporte" class="w-full h-2.5 bg-border-color rounded-lg appearance-none cursor-pointer slider-thumb" max="360" min="12" step="12" type="range" value="60" />
                        <div class="flex justify-between text-[11px] text-text-muted font-bold uppercase tracking-wider">
                            <span>1 ANO</span>
                            <span>30 ANOS</span>
                        </div>
                    </div>
                </div>

                <div class="lg:col-span-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div class="glass-panel p-6 rounded-2xl flex flex-col justify-center bg-text-main text-white sm:col-span-2 relative overflow-hidden">
                        <div class="absolute -right-10 -bottom-10 opacity-10">
                            <span class="material-icons text-9xl">account_balance_wallet</span>
                        </div>
                        <p class="text-xs text-slate-400 uppercase font-black tracking-widest mb-2 relative z-10">Patrimônio Bruto Acumulado</p>
                        <p id="calcPatrimonio" class="text-4xl md:text-5xl font-black text-white relative z-10">R$ 0,00</p>
                    </div>
                    
                    <div class="glass-panel p-6 rounded-2xl border-t-4 border-t-text-muted flex flex-col justify-center">
                        <div class="flex items-center gap-2 mb-2">
                            <span class="material-icons text-text-muted text-sm">payments</span>
                            <p class="text-[10px] text-text-muted uppercase font-black tracking-widest">Total do Seu Bolso</p>
                        </div>
                        <p id="calcTotalInvestido" class="text-2xl font-bold text-text-main">R$ 0,00</p>
                    </div>
                    
                    <div class="glass-panel p-6 rounded-2xl border-t-4 border-t-primary flex flex-col justify-center">
                        <div class="flex items-center gap-2 mb-2">
                            <span class="material-icons text-primary text-sm">savings</span>
                            <p class="text-[10px] text-text-muted uppercase font-black tracking-widest">Juros Ganhos (Selic)</p>
                        </div>
                        <p id="calcTotalJuros" class="text-2xl font-bold text-primary">+ R$ 0,00</p>
                    </div>
                </div>
            </div>
        </section>
        
        <section class="mt-24">
            <div class="flex items-end justify-between mb-10">
                <div>
                    <h2 class="text-3xl font-extrabold text-text-main tracking-tight">Produtos Sugeridos</h2>
                    <p class="text-text-muted mt-2">Melhores opções para potencializar seus rendimentos.</p>
                </div>
                <button class="text-primary font-bold text-sm flex items-center gap-2 hover:gap-3 transition-all border-b-2 border-transparent hover:border-primary pb-1 uppercase tracking-widest">
                    Ver todos <span class="material-icons text-base">east</span>
                </button>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="glass-panel p-8 rounded-2xl flex flex-col justify-between group hover:border-primary/30 transition-all hover:-translate-y-1">
                    <div>
                        <div class="flex justify-between items-start mb-6">
                            <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center text-primary">
                                <span class="material-icons">query_stats</span>
                            </div>
                            <span class="px-3 py-1 bg-slate-100 text-text-muted text-[10px] font-black rounded-full uppercase tracking-wider">Médio Prazo</span>
                        </div>
                        <h4 class="text-xl font-bold mb-3 text-text-main">Renda Fixa Plus</h4>
                        <p class="text-sm text-text-muted mb-8 leading-relaxed">Ideal para metas de médio prazo com liquidez diária após 90 dias.</p>
                        <div class="space-y-4 mb-10">
                            <div class="flex justify-between text-sm border-b border-border-color pb-2">
                                <span class="text-text-muted font-medium">Rentabilidade</span>
                                <span class="text-text-main font-bold">115% do CDI</span>
                            </div>
                            <div class="flex justify-between text-sm border-b border-border-color pb-2">
                                <span class="text-text-muted font-medium">Aporte Mínimo</span>
                                <span class="text-text-main font-bold">R$ 500,00</span>
                            </div>
                        </div>
                    </div>
                    <button class="w-full py-3 bg-background-light group-hover:bg-primary group-hover:text-white text-text-main font-bold rounded-xl transition-all uppercase tracking-wider text-xs">
                        Selecionar
                    </button>
                </div>
                
                <div class="glass-panel p-8 rounded-2xl flex flex-col justify-between group border-primary/20 shadow-xl shadow-primary/5 transition-all hover:-translate-y-1 relative">
                    <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-primary px-4 py-1.5 rounded-full text-[10px] font-black text-white uppercase tracking-[0.1em]">RECOMENDADO</div>
                    <div>
                        <div class="flex justify-between items-start mb-6">
                            <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center text-primary">
                                <span class="material-icons">savings</span>
                            </div>
                            <span class="px-3 py-1 bg-primary/10 text-primary text-[10px] font-black rounded-full uppercase tracking-wider">Exclusivo</span>
                        </div>
                        <h4 class="text-xl font-bold mb-3 text-text-main">Cota Capital</h4>
                        <p class="text-sm text-text-muted mb-8 leading-relaxed">A participação nos resultados da BarraCred que acelera seus sonhos.</p>
                        <div class="space-y-4 mb-10">
                            <div class="flex justify-between text-sm border-b border-border-color pb-2">
                                <span class="text-text-muted font-medium">Sobra Anual Est.</span>
                                <span class="text-primary font-black">12.5% a.a.</span>
                            </div>
                            <div class="flex justify-between text-sm border-b border-border-color pb-2">
                                <span class="text-text-muted font-medium">Aporte Mensal</span>
                                <span class="text-text-main font-bold">Automático</span>
                            </div>
                        </div>
                    </div>
                    <button class="w-full py-3 bg-primary text-white font-bold rounded-xl shadow-lg shadow-primary/20 transition-all uppercase tracking-wider text-xs hover:brightness-110">
                        Selecionar
                    </button>
                </div>
                
                <div class="glass-panel p-8 rounded-2xl flex flex-col justify-between group hover:border-primary/30 transition-all hover:-translate-y-1">
                    <div>
                        <div class="flex justify-between items-start mb-6">
                            <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center text-primary">
                                <span class="material-icons">verified_user</span>
                            </div>
                            <span class="px-3 py-1 bg-slate-100 text-text-muted text-[10px] font-black rounded-full uppercase tracking-wider">Proteção</span>
                        </div>
                        <h4 class="text-xl font-bold mb-3 text-text-main">Previdência Barra</h4>
                        <p class="text-sm text-text-muted mb-8 leading-relaxed">Segurança para o seu futuro com benefícios fiscais imediatos.</p>
                        <div class="space-y-4 mb-10">
                            <div class="flex justify-between text-sm border-b border-border-color pb-2">
                                <span class="text-text-muted font-medium">Taxa Adm.</span>
                                <span class="text-text-main font-bold">0.5% a.a.</span>
                            </div>
                            <div class="flex justify-between text-sm border-b border-border-color pb-2">
                                <span class="text-text-muted font-medium">Vantagem Fiscal</span>
                                <span class="text-text-main font-bold">Até 12%</span>
                            </div>
                        </div>
                    </div>
                    <button class="w-full py-3 bg-background-light group-hover:bg-primary group-hover:text-white text-text-main font-bold rounded-xl transition-all uppercase tracking-wider text-xs">
                        Selecionar
                    </button>
                </div>
            </div>
        </section>
        
        <section class="mt-24 relative rounded-[2rem] overflow-hidden min-h-[450px] flex items-center bg-text-main shadow-2xl">
            <img alt="Luxury travel destination" class="absolute inset-0 w-full h-full object-cover opacity-30" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCOQCp4YEqzhmE7PTFSjuBDr7W033KEjLIQ_r43EAtXJB7HZMAz3voki3UDP6tjPuwUmPwrQq0rqh8CfuixOpTn6FE5a1PbFSB1lQpn9dM0tzazc-B9_zQlOzU3FkpXaaT3mMGTeIWe5_JQLl8l_zgUGNU0lJEUo-cqoLUzv08vkymFTv5bUJ3o3N9_rkqRMi6wH3ozJ-E4WTVJUdOrNA4dMu5gqoh2vMTpdcw8BFwkyO2dYM_zsBBxxBhNNNwNqg20ISaaMP68MeI" />
            <div class="absolute inset-0 bg-gradient-to-r from-text-main via-text-main/70 to-transparent"></div>
            <div class="relative z-10 p-10 md:p-20 max-w-2xl">
                <span class="text-primary font-black uppercase tracking-[0.3em] text-xs mb-6 block">Inspiração do Dia</span>
                <h2 class="text-4xl md:text-5xl font-extrabold text-white mb-8 leading-tight">Sua próxima conquista começa com o primeiro depósito.</h2>
                <p class="text-slate-300 text-lg mb-10 leading-relaxed font-medium">
                    Pesquisas mostram que investidores que definem metas visuais têm 3x mais chances de completar seus objetivos financeiros. Estamos aqui para garantir que você chegue lá.
                </p>
                <div class="flex flex-col sm:flex-row gap-6">
                    <div class="flex -space-x-3">
                        <div class="w-12 h-12 rounded-full border-4 border-text-main bg-slate-300 shadow-lg"></div>
                        <div class="w-12 h-12 rounded-full border-4 border-text-main bg-slate-400 shadow-lg"></div>
                        <div class="w-12 h-12 rounded-full border-4 border-text-main bg-slate-500 shadow-lg"></div>
                    </div>
                    <p class="text-sm text-white/70 self-center font-bold">
                        <span class="text-white text-base font-black">+1.200 cooperados</span> já estão planejando o futuro.
                    </p>
                </div>
            </div>
        </section>
    </main>
    
    <footer class="mt-24 bg-white border-t border-border-color pt-16 pb-12">
        <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-4 gap-12">
            <div class="space-y-6">
                <div class="flex items-center gap-2">
                    <span class="material-icons text-primary text-2xl">account_balance</span>
                    <span class="text-xl font-black text-text-main">BarraCred</span>
                </div>
                <p class="text-sm text-text-muted leading-relaxed font-medium">
                    A cooperativa de crédito focada em oferecer as melhores soluções financeiras para você e sua família.
                </p>
            </div>
            <div>
                <h5 class="font-black mb-8 text-text-main uppercase text-[10px] tracking-widest">Serviços</h5>
                <ul class="space-y-4 text-sm font-bold text-text-muted">
                    <li><a class="hover:text-primary transition-colors" href="#">Investimentos</a></li>
                    <li><a class="hover:text-primary transition-colors" href="#">Crédito Pessoal</a></li>
                    <li><a class="hover:text-primary transition-colors" href="#">Seguros</a></li>
                    <li><a class="hover:text-primary transition-colors" href="#">Consórcios</a></li>
                </ul>
            </div>
            <div>
                <h5 class="font-black mb-8 text-text-main uppercase text-[10px] tracking-widest">Institucional</h5>
                <ul class="space-y-4 text-sm font-bold text-text-muted">
                    <li><a class="hover:text-primary transition-colors" href="#">Quem Somos</a></li>
                    <li><a class="hover:text-primary transition-colors" href="#">Transparência</a></li>
