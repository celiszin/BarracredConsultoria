@model BarracredConsultoria.Models.Usuario

@{
    Layout = null;
    var etapaAtual = 2;
    var totalEtapas = 5;
    var progressoPercent = (etapaAtual * 100) / totalEtapas;
    var perfilSelecionado = Model?.Objetivo ?? "Devedor";
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>BarraCred - Onboarding</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms"></script>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet" />
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        "primary": "#1EB53A",
                        "primary-dark": "#16912d",
                    },
                    fontFamily: { "sans": ["Montserrat", "sans-serif"] }
                }
            }
        }
    </script>
    <style type="text/css">
        body { font-family: 'Montserrat', sans-serif; }
        .profile-card { transition: all 0.3s ease; border-width: 2px; cursor: pointer; }
        .profile-card:hover { transform: translateY(-5px); border-color: #1EB53A; }
        .active-card { border-color: #1EB53A !important; background-color: #F0FDF4 !important; box-shadow: 0 10px 15px -3px rgba(30, 181, 58, 0.1); }
        .step-bar { background: linear-gradient(90deg, #1EB53A 0%, #29D04B 100%); }
    </style>
</head>
<body class="min-h-screen bg-white flex flex-col">
    <header class="w-full border-b border-gray-100 py-6 sticky top-0 bg-white z-50">
        <div class="max-w-5xl mx-auto px-6">
            <div class="flex items-center justify-between mb-4">
                <div class="flex items-center gap-2">
                    <span class="material-icons-round text-primary text-3xl">account_balance_wallet</span>
                    <span class="font-extrabold text-2xl text-primary">BarraCred</span>
                </div>
                <span class="text-sm font-bold text-primary">Etapa @etapaAtual de @totalEtapas</span>
            </div>
            <div class="w-full bg-gray-100 h-2 rounded-full overflow-hidden">
                <div class="step-bar h-full transition-all duration-700" style="width: @progressoPercent%"></div>
            </div>
        </div>
    </header>

    <main class="max-w-5xl mx-auto pt-16 pb-24 px-6 flex-grow">
        <div class="text-center mb-12">
            <h1 class="text-4xl font-extrabold text-gray-900 mb-4">Qual seu momento financeiro?</h1>
            <p class="text-gray-500 text-lg">Selecione o perfil que melhor descreve seu objetivo atual.</p>
        </div>

        <form id="onboardingForm" asp-action="SalvarOnboarding" asp-controller="Home" method="post">
            @* Campos ocultos para manter o estado do Usuário *@
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="Nome" />
            <input type="hidden" asp-for="Objetivo" id="inputObjetivo" value="@perfilSelecionado" />

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
                @* Card Poupador *@
                <div onclick="selectProfile('Poupador')" id="card-Poupador" 
                     class="profile-card flex flex-col items-center p-8 bg-white border border-gray-100 rounded-2xl @(perfilSelecionado == "Poupador" ? "active-card" : "")">
                    <div class="w-20 h-20 bg-green-50 rounded-full flex items-center justify-center mb-6">
                        <span class="material-icons-round text-primary text-4xl">savings</span>
                    </div>
                    <h3 class="text-xl font-bold mb-2">Poupador</h3>
                    <p class="text-gray-500 text-sm text-center">Consigo guardar dinheiro todos os meses e mantenho uma reserva sólida.</p>
                </div>

                @* Card Devedor *@
                <div onclick="selectProfile('Devedor')" id="card-Devedor" 
                     class="profile-card flex flex-col items-center p-8 bg-white border border-gray-100 rounded-2xl @(perfilSelecionado == "Devedor" ? "active-card" : "")">
                    <div class="w-20 h-20 bg-green-50 rounded-full flex items-center justify-center mb-6">
                        <span class="material-icons-round text-primary text-4xl">credit_card_off</span>
                    </div>
                    <h3 class="text-xl font-bold mb-2">Devedor</h3>
                    <p class="text-gray-500 text-sm text-center">Estou com dificuldades, possuo contas em atraso e preciso de crédito.</p>
                </div>

                @* Card Investidor *@
                <div onclick="selectProfile('Investidor')" id="card-Investidor" 
                     class="profile-card flex flex-col items-center p-8 bg-white border border-gray-100 rounded-2xl @(perfilSelecionado == "Investidor" ? "active-card" : "")">
                    <div class="w-20 h-20 bg-green-50 rounded-full flex items-center justify-center mb-6">
                        <span class="material-icons-round text-primary text-4xl">trending_up</span>
                    </div>
                    <h3 class="text-xl font-bold mb-2">Investidor</h3>
                    <p class="text-gray-500 text-sm text-center">Já tenho reservas e busco as melhores rentabilidades para meu patrimônio.</p>
                </div>
            </div>

            <div class="flex items-center justify-center gap-3 text-gray-400 bg-gray-50 w-fit mx-auto px-6 py-3 rounded-full">
                <span class="material-icons-round text-xl">verified_user</span>
                <p class="text-sm font-medium">Suas respostas são confidenciais e protegidas.</p>
            </div>
        </form>
    </main>

    <footer class="w-full bg-white border-t border-gray-100 py-8">
        <div class="max-w-5xl mx-auto px-6 flex items-center justify-between">
            <a asp-controller="Home" asp-action="Index" class="flex items-center gap-2 px-8 py-4 font-bold text-gray-400 hover:text-black transition-colors rounded-xl">
                <span class="material-icons-round">arrow_back</span> Anterior
            </a>
            <button type="submit" form="onboardingForm" class="bg-primary hover:bg-primary-dark text-white font-extrabold px-14 py-5 rounded-2xl shadow-lg transition-all transform hover:scale-105 active:scale-95 flex items-center gap-2">
                Próxima Etapa <span class="material-icons-round">arrow_forward</span>
            </button>
        </div>
    </footer>

    <script>
        function selectProfile(perfil) {
            document.getElementById('inputObjetivo').value = perfil;

            document.querySelectorAll('.profile-card').forEach(card => {
                card.classList.remove('active-card');
            });

            document.getElementById('card-' + perfil).classList.add('active-card');
        }
    </script>
</body>
</html>