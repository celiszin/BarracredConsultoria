@model BarracredConsultoria.Models.Usuario

@{
    Layout = null;
    var etapaAtual = 2;
    var totalEtapas = 5;
    var progressoPercent = (etapaAtual * 100) / totalEtapas;
    var metaSelecionada = Model?.Objetivo ?? "Sair das Dívidas";
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>BarraCred - Sonhos e Metas</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms"></script>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet" />
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        "primary": "#1EB53A",
                        "primary-dark": "#16912d",
                    },
                    fontFamily: { "sans": ["Montserrat", "sans-serif"] }
                }
            }
        }
    </script>
    <style type="text/css">
        body { font-family: 'Montserrat', sans-serif; }
        .profile-card { transition: all 0.3s ease; border-width: 2px; cursor: pointer; }
        .profile-card:hover { transform: translateY(-5px); border-color: #1EB53A; }
        .active-card { border-color: #1EB53A !important; background-color: #F0FDF4 !important; box-shadow: 0 10px 15px -3px rgba(30, 181, 58, 0.1); }
        .step-bar { background: linear-gradient(90deg, #1EB53A 0%, #29D04B 100%); }
    </style>
</head>
<body class="min-h-screen bg-white flex flex-col">
    <header class="w-full border-b border-gray-100 py-6 sticky top-0 bg-white z-50">
        <div class="max-w-5xl mx-auto px-6">
            <div class="flex items-center justify-between mb-4">
                <div class="flex items-center gap-2">
                    <span class="material-icons-round text-primary text-3xl">account_balance_wallet</span>
                    <span class="font-extrabold text-2xl text-primary">BarraCred</span>
                </div>
                <span class="text-sm font-bold text-primary">Etapa @etapaAtual de @totalEtapas</span>
            </div>
            <div class="w-full bg-gray-100 h-2 rounded-full overflow-hidden">
                <div class="step-bar h-full transition-all duration-700" style="width: @progressoPercent%"></div>
            </div>
        </div>
    </header>

    <main class="max-w-5xl mx-auto pt-16 pb-24 px-6 flex-grow">
        <div class="text-center mb-12">
            <h1 class="text-4xl font-extrabold text-gray-900 mb-4">Qual é o seu maior sonho hoje?</h1>
            <p class="text-gray-500 text-lg">Defina sua principal meta para que possamos ajudar você a alcançá-la.</p>
        </div>

        <form id="onboardingForm" asp-action="SalvarOnboarding" asp-controller="Home" method="post">
            @* Campos ocultos para manter o estado do Usuário *@
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="Nome" />
            <input type="hidden" asp-for="Objetivo" id="inputObjetivo" value="@metaSelecionada" />

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
                
                @* Card Sair das Dívidas *@
                <div onclick="selectMeta('Sair das Dívidas', 'card-dividas')" id="card-dividas" 
                     class="profile-card flex flex-col items-center p-8 bg-white border border-gray-100 rounded-2xl @(metaSelecionada == "Sair das Dívidas" ? "active-card" : "")">
                    <div class="w-20 h-20 bg-red-50 rounded-full flex items-center justify-center mb-6">
                        <span class="material-icons-round text-red-500 text-4xl">money_off</span>
                    </div>
                    <h3 class="text-xl font-bold mb-2 text-center">Sair das Dívidas</h3>
                    <p class="text-gray-500 text-sm text-center">Quero limpar meu nome, organizar minhas finanças e voltar a ter paz.</p>
                </div>

                @* Card Comprar um Bem *@
                <div onclick="selectMeta('Comprar um Bem', 'card-bens')" id="card-bens" 
                     class="profile-card flex flex-col items-center p-8 bg-white border border-gray-100 rounded-2xl @(metaSelecionada == "Comprar um Bem" ? "active-card" : "")">
                    <div class="w-20 h-20 bg-blue-50 rounded-full flex items-center justify-center mb-6">
                        <span class="material-icons-round text-blue-500 text-4xl">home</span>
                    </div>
                    <h3 class="text-xl font-bold mb-2 text-center">Comprar um Bem</h3>
                    <p class="text-gray-500 text-sm text-center">Quero juntar dinheiro para comprar minha casa própria, carro ou outro bem.</p>
                </div>

                @* Card Liberdade Financeira *@
                <div onclick="selectMeta('Liberdade Financeira', 'card-liberdade')" id="card-liberdade" 
                     class="profile-card flex flex-col items-center p-8 bg-white border border-gray-100 rounded-2xl @(metaSelecionada == "Liberdade Financeira" ? "active-card" : "")">
                    <div class="w-20 h-20 bg-green-50 rounded-full flex items-center justify-center mb-6">
                        <span class="material-icons-round text-primary text-4xl">flight_takeoff</span>
                    </div>
                    <h3 class="text-xl font-bold mb-2 text-center">Liberdade Financeira</h3>
                    <p class="text-gray-500 text-sm text-center">Quero criar uma reserva forte, investir e viver de rendimentos no futuro.</p>
                </div>

            </div>

            <div class="flex items-center justify-center gap-3 text-gray-400 bg-gray-50 w-fit mx-auto px-6 py-3 rounded-full">
                <span class="material-icons-round text-xl">verified_user</span>
                <p class="text-sm font-medium">Suas metas nos ajudam a personalizar suas consultorias.</p>
            </div>
        </form>
    </main>

    <footer class="w-full bg-white border-t border-gray-100 py-8">
        <div class="max-w-5xl mx-auto px-6 flex items-center justify-between">
            <a asp-controller="Home" asp-action="Index" class="flex items-center gap-2 px-8 py-4 font-bold text-gray-400 hover:text-black transition-colors rounded-xl">
                <span class="material-icons-round">arrow_back</span> Voltar ao Painel
            </a>
            <button type="submit" form="onboardingForm" class="bg-primary hover:bg-primary-dark text-white font-extrabold px-14 py-5 rounded-2xl shadow-lg transition-all transform hover:scale-105 active:scale-95 flex items-center gap-2">
                Salvar Minha Meta <span class="material-icons-round">arrow_forward</span>
            </button>
        </div>
    </footer>

    <script>
        function selectMeta(metaName, cardId) {
            document.getElementById('inputObjetivo').value = metaName;

            document.querySelectorAll('.profile-card').forEach(card => {
                card.classList.remove('active-card');
            });

            document.getElementById(cardId).classList.add('active-card');
        }
    </script>
</body>
</html>