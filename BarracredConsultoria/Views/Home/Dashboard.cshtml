@model BarracredConsultoria.ViewModels.ConsultoriaViewModel
@{
    Layout = null;
    bool emAlerta = Model.CondicaoFinanceira.StatusAtual == "Alerta";
    
    // Configurações de data para o Script do Calendário
    var dataInicial = Model.Agendamento != null ? Model.Agendamento.DataHora : DateTime.Now;
    var anoAtual = dataInicial.Year;
    var mesAtual = dataInicial.Month - 1; // JS usa 0-11
    var diaAtual = dataInicial.Day;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Painel BarraCred | @Model.Usuario.Nome</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800&family=Inter:wght@400;500;600;700&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@@latest/dist/tabler-icons.min.css">
    
    <link rel="stylesheet" href="/css/site-barracred.css" />
    <link rel="stylesheet" href="/css/agendamento.css" />
    
    <style>
        /* Ajustes de fidelidade para integração no Dashboard */
        .dashboard-main { padding: 40px 0; }
        .calendar-card { box-shadow: none; padding: 0; background: transparent; }
        .dashboard-grid { align-items: start; }
        .back-home { color: var(--verde-primary); text-decoration: none; font-weight: 600; font-size: 14px; transition: 0.2s; }
        .back-home:hover { opacity: 0.8; }
    </style>
</head>
<body class="bg-light">

<nav class="navbar">
    <div class="container nav-container">
        <div class="logo">
            <div class="logo-icon"><i class="fas fa-building"></i></div>
            <div class="logo-text">Barra<span>Cred</span></div>
        </div>
        <div class="user-menu" style="display: flex; align-items: center; gap: 20px;">
            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Admin" asp-action="Index" style="color: #ef4444; font-weight: 800; text-decoration: none; font-size: 13px; border: 1px solid #ef4444; padding: 5px 12px; border-radius: 6px;">
                    <i class="fas fa-shield-alt"></i> PAINEL ADMIN
                </a>
            }

            <a asp-controller="Home" asp-action="Index" class="back-home">
                <i class="fas fa-home"></i> Início
            </a>

            <span class="user-name"><i class="fas fa-user-circle"></i> @Model.Usuario.Nome</span>
            
            <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline;">
                <button type="submit" class="logout-btn" style="background: none; border: none; color: #ef4444; font-weight: 700; cursor: pointer; font-size: 14px;">SAIR</button>
            </form>
        </div>
    </div>
</nav>

<main class="container dashboard-main">
    <div class="dashboard-grid">
        
        <div style="display: flex; flex-direction: column; gap: 30px;">
            <div class="card-dash @(emAlerta ? "border-alert" : "border-success")">
                <h3><i class="fas fa-wallet" style="color: var(--verde-primary);"></i> Saúde Financeira</h3>
                <div class="status-badge @(emAlerta ? "bg-alert" : "bg-success")">
                    Status Atual: @Model.CondicaoFinanceira.StatusAtual
                </div>
                <div class="data-row">
                    <span>Sua Renda:</span>
                    <strong>@Model.CondicaoFinanceira.RendaMensal.ToString("C")</strong>
                </div>
                <div class="data-row">
                    <span>Total em Dívidas:</span>
                    <strong class="@(emAlerta ? "text-danger" : "")">@Model.CondicaoFinanceira.TotalDividas.ToString("C")</strong>
                </div>
            </div>

            <div class="card-dash border-success">
                <h3><i class="fas fa-user-tie" style="color: var(--verde-primary);"></i> Consultor Responsável</h3>
                <div style="display: flex; align-items: center; gap: 15px; margin: 10px 0;">
                    <img src="https://ui-avatars.com/api/?name=Adilson+Nascimento&background=008744&color=fff&size=64" style="border-radius: 50%;">
                    <div>
                        <strong style="display:block; font-size: 18px;">Adilson Nascimento</strong>
                        <span style="color: var(--text-gray); font-size: 14px;">Especialista em Patrimônio</span>
                    </div>
                </div>
                <div class="resources-card" style="margin-top: 20px; cursor: pointer;">
                    <div class="resources-text">
                        <h4 style="font-size: 13px; color: #a8d5b8;">Recursos de Apoio</h4>
                        <p style="color: white; font-weight: 600;">Solicitar planilha de gastos</p>
                    </div>
                    <div class="resources-icon" style="background: #2d7a52; padding: 8px; border-radius: 8px;">
                        <i class="ti ti-file-text" style="color: white; font-size: 20px;"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="card-dash border-success">
            <h3><i class="fas fa-calendar-check" style="color: var(--verde-primary);"></i> Agendamento de Consultoria</h3>
            
            @if (!User.IsInRole("Admin"))
            {
                <div class="calendar-card" style="margin-top: 20px;">
                    <div class="calendar-header">
                        <span class="month-year" id="monthYearDisplay"></span>
                        <div class="month-nav">
                            <i class="ti ti-chevron-left" id="prevMonth"></i>
                            <i class="ti ti-chevron-right" id="nextMonth"></i>
                        </div>
                    </div>
                    <div class="weekdays">
                        <span class="weekday">D</span><span class="weekday">S</span><span class="weekday">T</span>
                        <span class="weekday">Q</span><span class="weekday">Q</span><span class="weekday">S</span><span class="weekday">S</span>
                    </div>
                    <div class="calendar-days" id="calendarDays"></div>
                </div>

                @if (Model.Agendamento != null)
                {
                    <div class="reminder-card" style="margin: 20px 0;">
                        <div class="reminder-icon"><i class="ti ti-calendar-event"></i></div>
                        <div class="reminder-content">
                            <div class="reminder-label">CONSULTA PRÓXIMA</div>
                            <div class="reminder-datetime">@Model.Agendamento.DataHora.ToString("dd MMM • HH:mm")</div>
                            <div class="reminder-title">Status: @Model.Agendamento.Status</div>
                        </div>
                    </div>
                }

                <form asp-controller="Home" asp-action="SalvarAgendamento" method="post" id="formAgendamento">
                    <input type="hidden" name="agendamentoId" value="@(Model.Agendamento?.Id ?? 0)" />
                    <input type="hidden" name="dataEscolhida" id="dataEscolhidaHidden" />

                    <div class="time-picker-container" style="margin-top: 15px;">
                        <div class="new-appointment-text">
                            <h4 style="font-size: 14px; color: var(--verde-primary);">Escolher Horário</h4>
                        </div>
                        <input type="time" id="horaEscolhida" required class="time-picker-input" 
                               value="@(Model.Agendamento != null ? Model.Agendamento.DataHora.ToString("HH:mm") : "10:30")" />
                    </div>

                    <button type="submit" class="new-appointment-card" style="margin-top: 12px; width: 100%;">
                        <div class="new-appointment-text">
                            <h4 style="font-weight: 700;">Confirmar Horário</h4>
                            <p style="font-size: 12px;">Gravar agendamento no sistema</p>
                        </div>
                        <div class="plus-icon" style="background: var(--verde-primary); border: none;">
                            <i class="ti ti-check" style="color: white;"></i>
                        </div>
                    </button>
                </form>
            }
            else
            {
                <div style="text-align: center; padding: 60px 20px; color: var(--text-gray);">
                    <i class="fas fa-user-shield" style="font-size: 50px; opacity: 0.2; margin-bottom: 20px;"></i>
                    <h4 style="color: var(--text-dark);">Modo Administrador</h4>
                    <p>A gestão de agendamentos é exclusiva para cooperados. Utilize o Painel Admin para aprovações.</p>
                </div>
            }
        </div>

    </div>
</main>

<div id="toastMessage" class="toast-message"></div>
<div id="toastMsg" class="toast-msg"></div>

<script src="/js/site-barracred.js"></script>

@if (!User.IsInRole("Admin"))
{
    <script>
        const CONFIG_DATA = {
            ano: @anoAtual,
            mes: @mesAtual, 
            dia: @diaAtual
        };
    </script>
    <script src="/js/agendamento.js"></script>
}

@if (TempData["MensagemSucesso"] != null) {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const msg = "@Html.Raw(TempData["MensagemSucesso"])";
            if(typeof showToast === 'function') showToast(msg);
            else if(typeof showMessage === 'function') showMessage(msg);
        });
    </script>
}
</body>
</html>