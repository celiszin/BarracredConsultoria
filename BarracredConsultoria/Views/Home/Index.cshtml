@model BarracredConsultoria.ViewModels.ConsultoriaViewModel

@{
    ViewData["Title"] = "BarraCred - Portal de Consultoria e Experts";
    Layout = null; 

    bool temDividas = Model.CondicaoFinanceira.TotalDividas > 0;
    string corStatus = temDividas ? "color: #ef4444;" : "color: #008744;";
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>@ViewData["Title"]</title>
  
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@@latest/dist/tabler-icons.min.css" rel="stylesheet">
  
  <link rel="stylesheet" href="~/css/painel-cooperado.css" asp-append-version="true" />
</head>
<body>

  <div class="experts-layout">
    
    <aside class="aside-menu">
      <div class="aside-container">
        <div class="logo-aside">
          <div class="logo-aside-icon">
             <span class="material-icons-round text-white">account_balance</span>
          </div>
          <span>Barra<span style="color: #008744">Cred</span></span>
        </div>

        <div class="nav-wrapper">
          <nav class="nav-menu">
            <a class="nav-item active" asp-controller="Home" asp-action="Index">
              <span class="nav-icon">dashboard</span>
              <span class="nav-text">Painel do Cooperado</span>
            </a>
            <a class="nav-item" asp-controller="Servicos" asp-action="Index">
              <span class="nav-icon">insights</span>
              <span class="nav-text">Meus Serviços</span>
            </a>
           <a class="nav-item" asp-controller="Home" asp-action="Sonhos">
             <span class="nav-icon">star</span>
            <span class="nav-text">Sonhos e Metas</span>
            </a>
            <a class="nav-item" asp-controller="Home" asp-action="Simulador">
              <span class="nav-icon">calculate</span>
             <span class="nav-text">Simuladores</span>
            </a>
            <a class="nav-item" href="#">
              <span class="nav-icon">support_agent</span>
              <span class="nav-text">Experts Roster</span>
            </a>
          </nav>
        </div>
      </div>
      
      <div class="user-profile">
        <div class="user-info">
          <div class="user-avatar">
            <span class="material-icons-round">person</span>
          </div>
          <div class="user-details">
            <div class="user-name">@Model.Usuario.Nome</div>
            <div class="user-plan">Cooperado BarraCred</div>
          </div>
        </div>
        
        <form asp-controller="Account" asp-action="Logout" method="post" style="margin-top: 16px; width: 100%;">
          <button type="submit" class="nav-item" style="color: #ef4444; width: 100%; padding: 8px 12px;">
            <span class="nav-icon">logout</span>
            <span class="nav-text">Sair da Conta</span>
          </button>
        </form>

      </div>
    </aside>

    <div class="experts-sidebar">
      <div class="experts-header">
        <div class="header-row">
          <span class="header-title">Experts Disponíveis</span>
          <span class="realtime-badge">Real-time</span>
        </div>
        <div class="search-wrapper">
          <i class="ti ti-search search-icon"></i>
          <input type="text" class="search-input" id="searchInput" placeholder="Filtrar consultores...">
        </div>
      </div>

      <div class="consultants-list" id="consultantsList">
        <div class="consultant-item active" data-expert="Adilson Nascimento">
          <div class="consultant-avatar"><img src="//scontent-atl3-3.cdninstagram.com/v/t51.82787-19/559168273_18294070000252713_1285691012925670037_n.jpg?stp=dst-jpg_s150x150_tt6&efg=eyJ2ZW5jb2RlX3RhZyI6InByb2ZpbGVfcGljLmRqYW5nby4xMDgwLmMyIn0&_nc_ht=scontent-atl3-3.cdninstagram.com&_nc_cat=109&_nc_oc=Q6cZ2gGHIK21IAQo2IdQMdQaYfIeFTdj_GVI65C0orhgCs97jIL46eSmj4G1hzJ552HVqFk&_nc_ohc=epffklorWSsQ7kNvwF1AJzn&_nc_gid=7MN-7E5OAYkmnb614jMiDg&edm=AP4sbd4BAAAA&ccb=7-5&oh=00_Af0hhCXyJOwrVExo_6pRyD-5xWRvKi43lIkMSpkv63Oq0w&oe=69F16E24&_nc_sid=7a9f4bplaceholderIfAbsent=true" alt="Consultor"></div>
          <div class="consultant-info">
            <div class="consultant-name">Adilson Nascimento</div>
            <div class="consultant-specialty">Gestão de Patrimônio</div>
          </div>
          <div class="status-badge available">● Disponível</div>
        </div>
      </div>
    </div>

    <div class="content-area">
      
      <div class="bc-header">
        <span class="bc-tag-top">Clínica Financeira Premium</span>
        <h2 class="bc-title">Painel do Cooperado</h2>
        <p class="bc-subtitle">Análise atualizada em: <span>@Model.Usuario.DataAnalise.ToString("dd/MM/yyyy")</span></p>
      </div>

      @if (TempData["MensagemSucesso"] != null)
      {
        <div class="bc-alert-success">
          <span class="material-symbols-outlined">check_circle</span>
          <span><strong>Sucesso!</strong> @TempData["MensagemSucesso"]</span>
        </div>
      }

      <div class="bc-grid">
        
        <div class="bc-card bc-card-highlight">
          <div class="bc-card-header">
            <div class="bc-icon-box"><span class="material-symbols-outlined">trending_up</span></div>
            <h4 class="bc-card-title">Seu Momento Financeiro</h4>
          </div>
          <hr class="bc-hr" />
          
          <p class="bc-status-text" style="@corStatus">@Model.CondicaoFinanceira.StatusAtual</p>
          
          <ul class="bc-list">
            <li class="bc-list-item">
              <span class="bc-list-label">Renda Mensal:</span>
              <strong class="bc-list-value">@Model.CondicaoFinanceira.RendaMensal.ToString("C")</strong>
            </li>
            <li class="bc-list-item">
              <span class="bc-list-label">Dívidas Totais:</span>
              <strong class="bc-list-value" style="@corStatus">@Model.CondicaoFinanceira.TotalDividas.ToString("C")</strong>
            </li>
            <li class="bc-list-item">
              <span class="bc-list-label">Seu Maior Objetivo:</span>
              <span class="bc-tag">@Model.Usuario.Objetivo</span>
            </li>
          </ul>
        </div>

        <div class="bc-card">
          <div class="bc-card-header">
            <div class="bc-icon-box"><span class="material-symbols-outlined">forum</span></div>
            <h4 class="bc-card-title">Consultoria Especializada</h4>
          </div>
          <hr class="bc-hr" />
          
          @if (Model.Agendamento != null)
          {
            <div class="bc-agenda-box">
              <div class="bc-agenda-date">
                <span class="bc-agenda-day">@Model.Agendamento.DataHora.ToString("dd")</span>
                <span class="bc-agenda-month">@Model.Agendamento.DataHora.ToString("MMM")</span>
              </div>
              <div>
                <span class="bc-agenda-title">Consulta às @Model.Agendamento.DataHora.ToString("HH:mm")</span>
                <span class="bc-agenda-status">Status: @Model.Agendamento.Status</span>
              </div>
            </div>
          }

          <form asp-controller="Home" asp-action="SalvarAgendamento" method="post" class="bc-form">
            <input type="hidden" name="agendamentoId" value="@(Model.Agendamento != null ? Model.Agendamento.Id : 0)" />
            
            <div class="bc-input-group">
              <label for="dataEscolhida" class="bc-label">
                @(Model.Agendamento != null ? "Remarcar Horário:" : "Agendar Novo Horário:")
              </label>
              <span class="material-symbols-outlined bc-input-icon">calendar_month</span>
              <input type="datetime-local" id="dataEscolhida" name="dataEscolhida" required class="bc-input" />
            </div>
            
            <button type="submit" class="bc-btn">
              <span class="material-symbols-outlined">event_available</span>
              Confirmar Agendamento
            </button>
          </form>
        </div>

      </div>

      <div class="bc-card" style="margin-bottom: 32px;">
        <div class="bc-iframe-toolbar">
          <div class="bc-iframe-titles">
            <div class="bc-icon-box"><span class="material-symbols-outlined" id="form-icon">assignment</span></div>
            <div>
              <h4 class="bc-card-title" id="form-title">Pesquisa de Satisfação</h4>
              <p class="bc-iframe-subtitle" id="form-subtitle">Sua opinião é fundamental para nós.</p>
            </div>
          </div>
          <button onclick="marcarComoRespondido()" id="btn-concluir" class="bc-btn-secondary">
            <span class="material-symbols-outlined">done_all</span> Já respondi
          </button>
        </div>
        
        <div class="bc-iframe-container" id="form-container">
          <iframe id="iframe-satisfacao" src="https://beforms.becompliance.com/67bca1d1f0eede0009c7b3b3" width="100%" height="600" frameborder="0"></iframe>
          <iframe id="iframe-final" allowtransparency="true" src="https://2fjnw12b.forms.app/form/69a02b5db668063afa589b63" frameborder="0" style="width: 100%; height:80vh; border:none; display:none;"></iframe>
        </div>
      </div>

      <div class="toolbar">
        <div class="filters">
          <div class="filter-select" id="specialtyFilter">
            <span class="filter-label">Especialidade</span>
            <span class="filter-value" id="selectedSpecialty">Todas Especialidades</span>
            <i class="ti ti-chevron-down" style="font-size: 16px; color: #6b7280;"></i>
          </div>
        </div>
      </div>

      <div class="calendar-container">
        <div class="calendar-header">
          <div class="calendar-header-cell"><span class="calendar-header-day">Horário</span></div>
          <div class="calendar-header-cell"><span class="calendar-header-day">Segunda</span></div>
          <div class="calendar-header-cell"><span class="calendar-header-day">Terça</span></div>
          <div class="calendar-header-cell"><span class="calendar-header-day">Quarta</span></div>
          <div class="calendar-header-cell"><span class="calendar-header-day">Quinta</span></div>
          <div class="calendar-header-cell"><span class="calendar-header-day">Sexta</span></div>
        </div>
        <div class="calendar-body">
          <div class="calendar-row"><div class="time-cell">09:00 AM</div><div class="appointment-cell"><div class="appointment-card green"><div class="appointment-title">Reunião: Adilson Nascimento</div></div></div><div class="appointment-cell"></div><div class="appointment-cell"></div><div class="appointment-cell"></div><div class="appointment-cell"></div></div>
          <div class="calendar-row"><div class="time-cell">10:00 AM</div><div class="appointment-cell"></div><div class="appointment-cell"></div><div class="appointment-cell"></div><div class="appointment-cell"></div><div class="appointment-cell"></div></div>
        </div>
      </div>

    </div>
  </div>

  <script src="~/js/painel-cooperado.js" asp-append-version="true"></script>
</body>
</html>