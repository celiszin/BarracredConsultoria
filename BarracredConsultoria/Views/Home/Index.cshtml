@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BarraCred | Cooperativa de Crédito</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;800&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    
    <link rel="stylesheet" href="/css/site-barracred.css" />
</head>
<body>

<nav class="navbar">
    <div class="container nav-container">
        <div class="logo">
            <div class="logo-icon"><i class="fas fa-building"></i></div>
            <div class="logo-text">Barra<span>Cred</span></div>
        </div>
        <div class="nav-links">
            <a href="#servicos">Serviços</a>
            <a asp-controller="Home" asp-action="Dashboard" class="nav-login-link">Entrar no Painel</a>
        </div>
    </div>
</nav>

<section class="hero">
    <div class="container hero-container">
        <div class="hero-content">
            <div class="hero-badge">Clínica Financeira Premium</div>
            <h1 class="hero-title">Sua saúde<br>financeira<br><span>levada a sério.</span></h1>
            <p class="hero-description">A BarraCred oferece soluções personalizadas para você conquistar estabilidade e liberdade. O cuidado que o seu patrimônio merece.</p>
            <a asp-controller="Home" asp-action="Dashboard" class="btn-primary">
                <i class="fas fa-user-check" style="margin-right: 8px;"></i> Área do Cooperado
            </a>
        </div>
        <div class="hero-image">
            <img src="https://placehold.co/600x500/e8f5e9/008744?text=BarraCred+Consultoria" alt="Consultoria">
        </div>
    </div>
</section>

<section id="servicos" class="solucoes">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">Nossas Soluções</h2>
        </div>
        <div class="cards-grid">
            <div class="card-solucao">
                <div class="card-icon"><i class="fas fa-graduation-cap"></i></div>
                <h3 class="card-title">Educação Financeira</h3>
                <p class="card-description">Conteúdos exclusivos e workshops para que você aprenda a gerir seus recursos.</p>
                <a asp-controller="Home" asp-action="Dashboard" class="card-link">Acessar Portal <i class="fas fa-arrow-right"></i></a>
            </div>
            <div class="card-solucao">
                <div class="card-icon"><i class="fas fa-headset"></i></div>
                <h3 class="card-title">Consultoria Especializada</h3>
                <p class="card-description">Atendimento exclusivo com especialistas focados em seus objetivos.</p>
                <a asp-controller="Home" asp-action="Dashboard" class="card-link">Agendar Conversa <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>
    </div>
</section>

<footer class="footer">
    <div class="container footer-container">
        <div>
            <div class="logo"><div class="logo-icon"><i class="fas fa-building"></i></div><div class="logo-text">Barra<span>Cred</span></div></div>
            <p style="color: #6b7280; margin-top: 15px; max-width: 300px;">Sua parceira estratégica em saúde financeira. Comprometidos com a transparência e ética.</p>
        </div>
        <div>
            <h4 style="font-family:'Montserrat'; margin-bottom:15px;">Contato</h4>
            <p><i class="fas fa-phone" style="color:#008744; margin-right: 5px;"></i> 0800 123 4567</p>
            <p><i class="fas fa-envelope" style="color:#008744; margin-right: 5px;"></i> contato@barracred.com.br</p>
        </div>
    </div>
</footer>

<script src="/js/site-barracred.js"></script>

</body>
</html>