@model IEnumerable<BarracredConsultoria.Models.UsuarioViewModel>
@{
    ViewData["Title"] = "Gestão de Cooperados";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-confirmacoes.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/dist/tabler-icons.min.css">
}

<main class="main-content">
    <div class="header">
        <span class="greeting">Olá, @User.Identity.Name</span>
    </div>

    <h1 class="page-title">Solicitações Pendentes</h1>

    <div class="search-container">
        <i class="ti ti-search"></i>
        <input type="text" id="searchInput" placeholder="Filtrar por nome ou e-mail...">
    </div>

    <div class="card-list" id="cardList">
        @if (Model != null && Model.Any())
        {
            foreach (var usuario in Model)
            {
                <div class="card" data-id="@usuario.UsuarioId" data-name="@usuario.Nome">
                    <div class="card-header">
                        <span class="card-badge">@usuario.Perfil</span>
                        <span class="status-label">Aguardando</span>
                    </div>

                    <div class="user-profile">
                        @if (!string.IsNullOrEmpty(usuario.Foto)) {
                            <img src="@usuario.Foto" class="avatar" />
                        } else {
                            <div class="avatar-placeholder"><i class="ti ti-user"></i></div>
                        }
                        <h2 class="user-name">@usuario.Nome</h2>
                    </div>

                    <div class="user-details">
                        <span><i class="ti ti-mail"></i> @usuario.Email</span>
                        <span><i class="ti ti-calendar"></i> Nasc: @usuario.DataNascimento.ToString("dd/MM/yyyy")</span>
                    </div>

                    <div class="btn-group">
                        <button class="btn-approve" onclick="openModal('@usuario.UsuarioId', '@usuario.Nome', 'aprovar')">
                            <i class="ti ti-check"></i> Aprovar
                        </button>
                        <button class="btn-reject" onclick="openModal('@usuario.UsuarioId', '@usuario.Nome', 'rejeitar')">
                            <i class="ti ti-x"></i> Rejeitar
                        </button>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <i class="ti ti-users-off"></i>
                <p>Nenhuma solicitação pendente.</p>
            </div>
        }
    </div>
</main>

<div id="confirmModal" class="modal-overlay">
    <div class="modal-box">
        <div id="modalIconCircle" class="icon-circle">
            <i id="modalIcon" class="ti"></i>
        </div>
        <h3 id="modalTitle"></h3>
        <p id="modalMessage"></p>
        <div class="modal-actions">
            <button onclick="closeModal()" class="btn-cancel">Cancelar</button>
            <form id="modalForm" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="usuarioId" id="modalInputId" />
                <button type="submit" id="modalConfirmBtn" class="btn-confirm">Confirmar</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin-confirmacoes.js"></script>
}