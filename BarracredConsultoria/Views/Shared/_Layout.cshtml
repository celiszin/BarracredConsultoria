<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BarraCred | Clínica Financeira</title>
    
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary-green": "#008744",
                        "accent-green": "#1EB53A",
                        "dark-text": "#1A1A1A",
                        "light-divider": "#F0F0F0",
                        "surface-light": "#FFFFFF",
                    },
                    fontFamily: {
                        "display": ["Montserrat", "sans-serif"],
                        "sans": ["Montserrat", "sans-serif"]
                    }
                },
            },
        }
    </script>
    <style type="text/tailwindcss">
        .nav-shadow { box-shadow: 0 2px 15px rgba(0,0,0,0.05); }
        .card-hover { transition: all 0.3s ease; }
        .card-hover:hover { transform: translateY(-5px); box-shadow: 0 10px 30px rgba(0,0,0,0.08); }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body class="bg-white text-dark-text">
    <nav class="fixed top-0 w-full z-50 bg-white/95 backdrop-blur-md nav-shadow border-b border-light-divider">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-20">
                <div class="flex items-center gap-2">
                    <a asp-controller="Home" asp-action="Index" class="flex items-center gap-2">
                        <div class="w-10 h-10 bg-primary-green rounded flex items-center justify-center">
                            <span class="material-icons-round text-white">account_balance</span>
                        </div>
                        <span class="text-2xl font-extrabold tracking-tight text-dark-text">Barra<span class="text-primary-green">Cred</span></span>
                    </a>
                </div>
                <div class="hidden md:flex items-center space-x-10">
                    <a class="text-sm font-semibold text-dark-text hover:text-primary-green transition-colors" href="#servicos">Serviços</a>
                    <a class="text-sm font-semibold text-dark-text hover:text-primary-green transition-colors" href="#educacao">Educação</a>
                    <a class="text-sm font-semibold text-dark-text hover:text-primary-green transition-colors" href="#simuladores">Simuladores</a>
                    <a class="text-sm font-semibold text-dark-text hover:text-primary-green transition-colors" href="#sobre">Sobre Nós</a>
                </div>
                <div class="flex items-center gap-4">
                    <button class="px-6 py-2.5 bg-primary-green hover:bg-[#007038] text-white text-sm font-bold rounded transition-all flex items-center gap-2">
                        <span class="material-icons-round text-sm">login</span>
                        Área do Cooperado
                    </button>
                </div>
            </div>
        </div>
    </nav>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="bg-white border-t border-light-divider pt-24 pb-12">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid md:grid-cols-4 gap-16 mb-20">
                <div class="col-span-2">
                    <div class="flex items-center gap-2 mb-8">
                        <div class="w-9 h-9 bg-primary-green rounded flex items-center justify-center">
                            <span class="material-icons-round text-white text-lg">account_balance</span>
                        </div>
                        <span class="text-2xl font-extrabold tracking-tight text-dark-text">Barra<span class="text-primary-green">Cred</span></span>
                    </div>
                    <p class="text-gray-500 max-w-sm leading-relaxed mb-8 text-lg">
                        Sua parceira estratégica em saúde financeira. Comprometidos com a transparência, ética e o desenvolvimento dos nossos cooperados.
                    </p>
                    <div class="flex gap-5">
                        @* Substitua os ícones por fontes reais ou imagens locais se necessário *@
                        <a class="w-12 h-12 rounded-full border border-light-divider flex items-center justify-center hover:bg-primary-green hover:text-white transition-all" href="#"><i class="fab fa-facebook-f"></i></a>
                        <a class="w-12 h-12 rounded-full border border-light-divider flex items-center justify-center hover:bg-primary-green hover:text-white transition-all" href="#"><i class="fab fa-instagram"></i></a>
                    </div>
                </div>
                <div>
                    <h5 class="text-dark-text font-extrabold mb-8 text-lg">Links Rápidos</h5>
                    <ul class="space-y-4">
                        <li><a class="text-gray-500 hover:text-primary-green transition-colors font-medium" href="#">Simuladores</a></li>
                        <li><a class="text-gray-500 hover:text-primary-green transition-colors font-medium" href="#">Educação Financeira</a></li>
                        <li><a class="text-gray-500 hover:text-primary-green transition-colors font-medium" href="#">Canais de Atendimento</a></li>
                        <li><a class="text-gray-500 hover:text-primary-green transition-colors font-medium" href="#">Ouvidoria</a></li>
                    </ul>
                </div>
                <div>
                    <h5 class="text-dark-text font-extrabold mb-8 text-lg">Contato</h5>
                    <ul class="space-y-5">
                        <li class="flex items-center gap-4 text-gray-500 font-medium">
                            <span class="material-icons-round text-accent-green">phone</span> 0800 123 4567
                        </li>
                        <li class="flex items-center gap-4 text-gray-500 font-medium">
                            <span class="material-icons-round text-accent-green">email</span> contato@barracred.com.br
                        </li>
                    </ul>
                </div>
            </div>
            <div class="pt-10 border-t border-light-divider flex flex-col md:flex-row justify-between items-center gap-6 text-sm text-gray-400 font-medium">
                <p>&copy; @DateTime.Now.Year BarraCred Cooperativa de Crédito. Todos os direitos reservados.</p>
                <div class="flex gap-8">
                    <a class="hover:text-primary-green transition-colors" href="#">Políticas de Privacidade</a>
                    <a class="hover:text-primary-green transition-colors" href="#">Termos de Uso</a>
                </div>
            </div>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>